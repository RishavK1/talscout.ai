# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local preview / screenshot artifacts (never commit)
.cp*/
shot-*.png
*.screenshot.png

# AI assistant / skill tooling (never commit)
.agents/
skills-lock.json
.claude/
*.skill

# typescript
*.tsbuildinfo
next-env.d.ts

# AI assistant instruction files (never commit)
AGENTS.md
CLAUDE.md

# custom testing scripts (never commit)
/scripts/*.mjs
/scripts/*.ts

